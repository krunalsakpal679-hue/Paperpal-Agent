# ============================================================================
# Agent Paperpal — Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================================

# ── LLM Provider ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx          # Anthropic Claude API key

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://paperpal:paperpal_secret@postgres:5432/paperpal_db
POSTGRES_USER=paperpal
POSTGRES_PASSWORD=paperpal_secret
POSTGRES_DB=paperpal_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1                 # Celery uses DB 1

# ── AWS S3 / MinIO ──────────────────────────────────────────────────────────
AWS_S3_BUCKET=paperpal-uploads
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT_URL=http://minio:9000                  # Only for local dev with MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string        # JWT signing key

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development                                 # development | staging | production
LOG_LEVEL=INFO                                          # DEBUG | INFO | WARNING | ERROR
MAX_FILE_SIZE_MB=50                                     # Max upload size in MB
JRO_CACHE_TTL_SECONDS=604800                           # Journal Rule Object cache: 7 days

# ── Frontend ────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1          # Backend API URL for frontend
