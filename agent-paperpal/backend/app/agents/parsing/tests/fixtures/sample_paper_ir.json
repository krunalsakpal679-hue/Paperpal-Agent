        {
            "element_id": "el_4",
            "element_type": "paragraph",
            "raw_text": "Neural machine translation (NMT) has revolutionized the field of computational linguistics (Bahdanau, 2015). Recent transformer-based approaches have further improved translation quality significantly (Vaswani et al., 2017). Several studies have confirmed these improvements (Wu et al., 2016, p. 5).",
            "level": 0,
            "metadata": {
                "style_name": "Normal"
            },
            "content": [
